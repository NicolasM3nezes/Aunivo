# Meta Pixel (Meta Events Manager -> Data sources -> Pixel settings)
# Add the same variable to each Vercel environment that should send events.
NEXT_PUBLIC_META_PIXEL_ID=1761194491703570
NEXT_PUBLIC_ANALYTICS_DEBUG=false

# Optional server-side Meta Conversions API. Keep these server-only.
META_CONVERSIONS_API_TOKEN=
META_GRAPH_API_VERSION=v23.0
# META_TEST_EVENT_CODE=

# Canonical app origin used by Supabase confirmation callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Auth must allow:
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/redefinir-senha
# https://YOUR_DOMAIN/auth/callback
# https://YOUR_DOMAIN/auth/redefinir-senha
